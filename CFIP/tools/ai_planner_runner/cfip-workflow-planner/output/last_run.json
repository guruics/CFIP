{
  "workflowId": "medicaidPaymentReconciliation",
  "version": "1.0",
  "description": "Reconcile a Medicaid payment received in QuickBooks with corresponding claims in Athena and prepare adjustments if discrepancies are found. This workflow retrieves payment and claim data, compares amounts, requests approval for adjustments if needed, and outputs reconciliation results.",
  "trigger": {
    "type": "Manual",
    "description": "Triggered manually to reconcile a specific Medicaid payment."
  },
  "steps": [
    {
      "id": "step1",
      "type": "CAPABILITY",
      "name": "Retrieve Medicaid Payment from QuickBooks",
      "capabilityId": "quickbooks.payment.getMedicaidPayment",
      "parameters": {
        "paymentType": "Medicaid"
      }
    },
    {
      "id": "step2",
      "type": "CAPABILITY",
      "name": "Retrieve Corresponding Claims from Athena",
      "capabilityId": "athena.claim.getClaimsByPayment",
      "parameters": {
        "paymentId": "${step1.output.paymentId}"
      }
    },
    {
      "id": "step3",
      "type": "DECISION",
      "name": "Check for Payment and Claims Amount Match",
      "condition": "${step1.output.amount} == sum(${step2.output.claims.amountBilled})"
    },
    {
      "id": "step4",
      "type": "OUTPUT",
      "name": "Output Reconciliation Success",
      "parameters": {
        "message": "Payment amount matches total claims amount. No adjustments needed.",
        "paymentDetails": "${step1.output}",
        "claimsDetails": "${step2.output.claims}"
      },
      "condition": "step3 == true"
    },
    {
      "id": "step5",
      "type": "OUTPUT",
      "name": "Output Reconciliation Discrepancy",
      "parameters": {
        "message": "Discrepancy detected between payment and claims amounts. Prepare adjustments.",
        "paymentDetails": "${step1.output}",
        "claimsDetails": "${step2.output.claims}"
      },
      "condition": "step3 == false"
    },
    {
      "id": "step6",
      "type": "APPROVAL",
      "name": "Approve Adjustments for Discrepancy",
      "approvalRole": "BillingManager",
      "condition": "step3 == false"
    },
    {
      "id": "step7",
      "type": "CAPABILITY",
      "name": "Prepare Adjustment in Athena",
      "capabilityId": "athena.claim.adjustClaim",
      "parameters": {
        "claims": "${step2.output.claims}",
        "payment": "${step1.output}"
      },
      "condition": "step6.approved == true"
    },
    {
      "id": "step8",
      "type": "OUTPUT",
      "name": "Output Adjustment Completion",
      "parameters": {
        "message": "Adjustments prepared and recorded in Athena.",
        "adjustmentDetails": "${step7.output}"
      },
      "condition": "step6.approved == true"
    }
  ]
}